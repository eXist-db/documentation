  <model id="text-embedding-3-small" path="https://api.openai.com/v1" dimension="1536"/>
  <!-- Or Cohere: <model id="embed-english-v3.0" path="https://api.cohere.ai/v1" dimension="1024"/> -->
</vector-models>
